{
    "name":  "payflow",
    "private":  true,
    "packageManager":  "pnpm@10.28.2",
    "scripts":  {
                    "dev":  "pnpm --parallel --filter @payflow/web --filter @payflow/api-gateway dev",
                    "dev:web":  "pnpm --filter @payflow/web dev",
                    "dev:api":  "pnpm --filter @payflow/api-gateway dev",
                    "build":  "pnpm --filter @payflow/web build",
                    "build:web":  "pnpm --filter @payflow/web build",
                    "build:api":  "pnpm --filter @payflow/api-gateway build",
                    "preview":  "pnpm --filter @payflow/web preview",
                    "lint":  "pnpm --filter @payflow/web lint",
                    "deploy:api":  "pnpm --filter @payflow/api-gateway deploy",
                    "db:generate":  "pnpm --filter @payflow/db db:generate",
                    "db:migrate":  "pnpm --filter @payflow/db db:migrate",
                    "db:studio":  "pnpm --filter @payflow/db db:studio"
                },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "esbuild",
                                               "sharp",
                                               "workerd"
                                           ],
                 "overrides":  {
                                   "@types/react":  "19.2.14",
                                   "@types/react-dom":  "19.2.3"
                               }
             }
}

