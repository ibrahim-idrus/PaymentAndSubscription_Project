{
    "name":  "payflow",
    "private":  true,
    "packageManager":  "pnpm@10.28.2",
    "scripts":  {
                    "dev":  "pnpm --parallel --filter @payflow/web --filter @payflow/api-gateway dev",
                    "dev:all": "pnpm --parallel --filter @payflow/web --filter @payflow/api-gateway --filter @payflow/payment-worker --filter @payflow/webhook-worker --filter @payflow/subscription-worker --filter @payflow/notification-worker --filter @payflow/renewal-cron dev",
                    "dev:all:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
                    "dev:web":  "pnpm --filter @payflow/web dev",
                    "dev:api":  "pnpm --filter @payflow/api-gateway dev",
                    "build":  "pnpm --filter @payflow/web build",
                    "build:web":  "pnpm --filter @payflow/web build",
                    "build:api":  "pnpm --filter @payflow/api-gateway build",
                    "preview":  "pnpm --filter @payflow/web preview",
                    "lint":  "pnpm --filter @payflow/web lint",
                    "deploy:api":  "pnpm --filter @payflow/api-gateway run deploy",
                    "db:generate":  "pnpm --filter @payflow/db db:generate",
                    "db:migrate":  "pnpm --filter @payflow/db db:migrate",
                    "db:studio":  "pnpm --filter @payflow/db db:studio"
                },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "esbuild",
                                               "sharp",
                                               "workerd"
                                           ],
                 "overrides":  {
                                   "@types/react":  "19.2.14",
                                   "@types/react-dom":  "19.2.3",
                                   "drizzle-orm":  "^0.45.1"
                               }
             }
}

